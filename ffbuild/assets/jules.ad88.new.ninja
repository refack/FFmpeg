build libavdevice/libavdevice.a: CXX_STATIC_LIBRARY_LINKER__avdevice_ libavdevice/CMakeFiles/avdevice.dir/alldevices.c.o libavdevice/CMakeFiles/avdevice.dir/avdevice.c.o libavdevice/CMakeFiles/avdevice.dir/utils.c.o libavdevice/CMakeFiles/avdevice.dir/version.c.o libavdevice/CMakeFiles/avdevice.dir/lavfi.c.o libavdevice/CMakeFiles/avdevice.dir/oss_dec.c.o libavdevice/CMakeFiles/avdevice.dir/oss.c.o libavdevice/CMakeFiles/avdevice.dir/oss_enc.c.o || libavcodec/libavcodec.a libavfilter/libavfilter.a libavformat/libavformat.a libavutil/libavutil.a libswresample/libswresample.a libswscale/libswscale.a
  OBJECT_DIR = libavdevice/CMakeFiles/avdevice.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_COMPILE_PDB = libavdevice/CMakeFiles/avdevice.dir/avdevice.pdb
  TARGET_FILE = libavdevice/libavdevice.a
  TARGET_PDB = libavdevice/libavdevice.pdb
  TARGET_SUPPORT_DIR = libavdevice/CMakeFiles/avdevice.dir


#############################################
# Utility command for edit_cache

build libavdevice/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libavdevice && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build libavdevice/edit_cache: phony libavdevice/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build libavdevice/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libavdevice && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake --regenerate-during-build -S/app -B/app/build-cmake
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build libavdevice/rebuild_cache: phony libavdevice/CMakeFiles/rebuild_cache.util

