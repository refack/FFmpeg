build libavutil/CMakeFiles/gen_ffversion | ${cmake_ninja_workdir}libavutil/CMakeFiles/gen_ffversion: phony libavutil/ffversion.h


#############################################
# Custom command for libavutil/ffversion.h

build libavutil/ffversion.h | ${cmake_ninja_workdir}libavutil/ffversion.h: CUSTOM_COMMAND /app/ffbuild/version.sh
  COMMAND = cd /app/build-cmake/libavutil && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake -E make_directory /app/build-cmake/libavutil && /usr/bin/sh /app/ffbuild/version.sh /app ffversion.h
  DESC = Generating ffversion.h
  restat = 1

