#############################################
# Utility command for edit_cache

build libswresample/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libswresample && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build libswresample/edit_cache: phony libswresample/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build libswresample/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libswresample && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake --regenerate-during-build -S/app -B/app/build-cmake
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build libswresample/rebuild_cache: phony libswresample/CMakeFiles/rebuild_cache.util

