#############################################
# Utility command for edit_cache

build libavcodec/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libavcodec && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build libavcodec/edit_cache: phony libavcodec/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build libavcodec/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-cmake/libavcodec && /home/jules/.pyenv/versions/3.12.12/lib/python3.12/site-packages/cmake/data/bin/cmake --regenerate-during-build -S/app -B/app/build-cmake
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build libavcodec/rebuild_cache: phony libavcodec/CMakeFiles/rebuild_cache.util

# =============================================================================
# Write statements declared in CMakeLists.txt:
# /app/CMakeLists.txt
# =============================================================================

# =============================================================================
# Object build statements for STATIC_LIBRARY target avformat


#############################################
# Order-only phony target for avformat

build cmake_object_order_depends_target_avformat: phony || cmake_object_order_depends_target_avcodec cmake_object_order_depends_target_avutil cmake_object_order_depends_target_swresample

build libavformat/CMakeFiles/avformat.dir/allformats.c.o: C_COMPILER__avformat_unscanned_ /app/libavformat/allformats.c || cmake_object_order_depends_target_avformat
  DEFINES = -DHAVE_ACCESS=1 -DHAVE_ARPA_INET_H=1 -DHAVE_ASM_TYPES_H=1 -DHAVE_AV_CONFIG_H -DHAVE_DIRENT_H=1 -DHAVE_FCNTL=1 -DHAVE_FORK=1 -DHAVE_GETADDRINFO=1 -DHAVE_GETOPT=1 -DHAVE_GETRUSAGE=1 -DHAVE_GETTIMEOFDAY=1 -DHAVE_INET_ATON=1 -DHAVE_ISATTY=1 -DHAVE_LINUX_DMA_BUF_H=1 -DHAVE_LINUX_FB_H=1 -DHAVE_LINUX_PERF_EVENT_H=1 -DHAVE_LINUX_VIDEODEV2_H=1 -DHAVE_MALLOC_H=1 -DHAVE_MKSTEMP=1 -DHAVE_MMAP=1 -DHAVE_MPROTECT=1 -DHAVE_POLL_H=1 -DHAVE_PTHREAD_CANCEL=1 -DHAVE_PTHREAD_JOIN=1 -DHAVE_SCHED_GETAFFINITY=1 -DHAVE_SETRLIMIT=1 -DHAVE_STRERROR_R=1 -DHAVE_STRUCT_ADDRINFO=1 -DHAVE_STRUCT_GROUP_SOURCE_REQ=1 -DHAVE_STRUCT_IPV6_MREQ=1 -DHAVE_STRUCT_IP_MREQ_SOURCE=1 -DHAVE_STRUCT_POLLFD=1 -DHAVE_STRUCT_SOCKADDR_IN6=1 -DHAVE_SYSCONF=1 -DHAVE_SYS_PARAM_H=1 -DHAVE_SYS_RESOURCE_H=1 -DHAVE_SYS_SELECT_H=1 -DHAVE_SYS_TIME_H=1 -DHAVE_SYS_UN_H=1 -DHAVE_TEMPNAM=1 -DHAVE_TERMIOS_H=1 -DHAVE_UNISTD_H=1 -DHAVE_USLEEP=1 -DHAVE_VALGRIND_VALGRIND_H=1
